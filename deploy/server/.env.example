# Private single-tenant server edition. Copy to .env; start.sh fills generated values.
COMPOSE_PROJECT_NAME=eia-ai-server
RUNTIME_ROOT=./runtime
BACKUP_ROOT=./backups
DOCKER_SOCKET=/var/run/docker.sock

# Public domain or internal DNS name, without scheme or path.
SERVER_NAME=eia.internal.example
# `internal` uses Caddy's local CA. A public deployment can use an ACME email.
TLS_ISSUER=internal
BIND_ADDRESS=0.0.0.0
HTTP_PORT=80
HTTPS_PORT=443
BASIC_AUTH_USER=eia-admin
BASIC_AUTH_HASH=__GENERATE_ON_FIRST_START__

# Generated independently on first start; backend -> Hermes only.
HERMES_API_SERVER_KEY=__GENERATE_ON_FIRST_START__

# Model configuration managed by Hermes. custom, openai and deepseek are supported.
LLM_PROVIDER=custom
OPENAI_API_KEY=replace-with-real-model-api-key
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_MODEL=replace-with-real-model-name
LLM_MODEL=
LLM_BASE_URL=
CUSTOM_BASE_URL=
DEEPSEEK_API_KEY=

CADDY_IMAGE=caddy:2-alpine@sha256:5f5c8640aae01df9654968d946d8f1a56c497f1dd5c5cda4cf95ab7c14d58648
HERMES_IMAGE=eia-ai-hermes-controller:0.2.0
HERMES_TOOL_IMAGE=eia-ai-hermes-tools:0.2.0
BACKEND_IMAGE=eia-ai-backend:0.2.0
BACKUP_IMAGE=alpine:3.21@sha256:48b0309ca019d89d40f670aa1bc06e426dc0931948452e8491e3d65087abc07d
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
REQUIREMENTS_FILE=requirements.lock

HERMES_REASONING_EFFORT=xhigh
HERMES_MAX_TURNS=60
HERMES_MAX_CONCURRENT_RUNS=4
HERMES_REQUEST_TIMEOUT=3600
HERMES_TERMINAL_TIMEOUT=900
HERMES_WEB_BACKEND=ddgs
HERMES_WEB_SEARCH_BACKEND=ddgs
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
PARALLEL_API_KEY=

# Hermes native Docker terminal limits. CPU is a decimal core count; memory/disk are MB.
HERMES_TOOL_CPUS=2
HERMES_TOOL_MEMORY_MB=4096
HERMES_TOOL_DISK_MB=20480
CADDY_CPUS=0.50
CADDY_MEMORY=256m
CADDY_PIDS_LIMIT=128
BACKEND_CPUS=2.0
BACKEND_MEMORY=2g
BACKEND_PIDS_LIMIT=256
HERMES_CPUS=2.0
HERMES_MEMORY=4g
HERMES_PIDS_LIMIT=512
AUTO_BUILD_TOOLS=true
STARTUP_TIMEOUT=900
LOG_TAIL=200

# Leave blank for a non-root deploy user. Root deployments must explicitly set a
# non-root owner UID/GID so backend and tool output remain readable.
HOST_UID=
HOST_GID=
