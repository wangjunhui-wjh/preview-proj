# Desktop edition. start.sh/start.bat copies this file to .env.
# Never commit or send the generated .env because it contains model credentials.

COMPOSE_PROJECT_NAME=eia-desktop
APP_PORT=8501
HERMES_PORT=8642

# The only model configuration. The URL must be an OpenAI-compatible endpoint.
OPENAI_API_KEY=replace-with-real-model-api-key
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_MODEL=replace-with-real-model-name

# Generated automatically on first start. Keep it independent from the model key.
HERMES_API_SERVER_KEY=__GENERATE_ON_FIRST_START__

PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
REQUIREMENTS_FILE=requirements.lock
BACKUP_IMAGE=alpine:3.21@sha256:48b0309ca019d89d40f670aa1bc06e426dc0931948452e8491e3d65087abc07d
HERMES_REASONING_EFFORT=xhigh
HERMES_MAX_TURNS=60
HERMES_MAX_CONCURRENT_RUNS=2
HERMES_TERMINAL_TIMEOUT=900
HERMES_REQUEST_TIMEOUT=3600

# ddgs works without a key. The other providers are optional Hermes-native backends.
HERMES_WEB_BACKEND=ddgs
HERMES_WEB_SEARCH_BACKEND=ddgs
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
PARALLEL_API_KEY=
