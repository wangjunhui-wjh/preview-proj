# 环评前期研判 AI 助手 Docker Compose 配置
# 复制为 .env 后填写。不要把 .env 发给别人或提交到代码仓库。

# Web 页面端口。用户访问 http://服务器IP:8501
APP_PORT=8501

# Hermes 内部 Agent API 端口。默认只绑定宿主机 127.0.0.1，用于管理员排查。
HERMES_PORT=8642

# Docker 构建 Python 依赖时使用的 PyPI 镜像。网络好时也可以改成 https://pypi.org/simple
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 默认模式：Docker 只启动后端，后端连接宿主机已运行的 Hermes。
HERMES_BASE_URL=http://host.docker.internal:8642

# 可选全容器模式：取消下一行注释，并把 HERMES_BASE_URL 改为 http://hermes:8642
# COMPOSE_PROFILES=hermes

# 后端访问 Hermes 的内部鉴权 key。首次部署请改成随机长字符串。
HERMES_API_SERVER_KEY=change-this-to-a-random-long-string

# ===== 模型配置 =====
# custom: OpenAI-compatible 接口，使用 OPENAI_API_KEY / OPENAI_BASE_URL / LLM_MODEL
# deepseek: Hermes 内置 DeepSeek provider，使用 DEEPSEEK_API_KEY / LLM_MODEL
LLM_PROVIDER=custom
LLM_MODEL=gpt-5.5
LLM_BASE_URL=

# OpenAI-compatible 示例：
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.example.com/v1

# DeepSeek 示例：
DEEPSEEK_API_KEY=
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-v4-pro

# Agent 推理强度。可用 medium / high / xhigh，当前系统建议 xhigh。
HERMES_REASONING_EFFORT=xhigh
HERMES_MAX_TURNS=60
HERMES_REQUEST_TIMEOUT=3600

# Web Search。默认 ddgs 不需要 key；如接入专业搜索服务，可在这里填。
HERMES_WEB_BACKEND=ddgs
HERMES_WEB_SEARCH_BACKEND=ddgs
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
PARALLEL_API_KEY=
